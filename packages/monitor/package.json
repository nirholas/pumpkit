{
    "name": "@pumpkit/monitor",
    "version": "1.1.0",
    "private": true,
    "description": "Telegram bot + REST API for monitoring PumpFun creator fee & cashback claims on Solana with real-time notifications, SSE streaming, and webhooks",
    "license": "Apache-2.0",
    "author": "nirholas <https://github.com/nirholas> (https://x.com/nichxbt)",
    "homepage": "https://github.com/nirholas/atomic",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nirholas/atomic.git",
        "directory": "packages/monitor"
    },
    "bugs": {
        "url": "https://github.com/nirholas/atomic/issues"
    },
    "type": "module",
    "main": "dist/index.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "keywords": [
        "solana",
        "pumpfun",
        "telegram",
        "bot",
        "fee-claims",
        "monitor",
        "rest-api",
        "sse",
        "webhooks"
    ],
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "api": "ENABLE_API=true API_ONLY=true tsx src/index.ts",
        "api:dev": "ENABLE_API=true API_ONLY=true tsx watch src/index.ts",
        "dev:full": "ENABLE_API=true tsx watch src/index.ts",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "lint": "node ../../tools/lint-check.mjs ."
    },
    "dependencies": {
        "@solana/web3.js": "^1.98.0",
        "bs58": "^6.0.0",
        "dotenv": "^17.4.2",
        "grammy": "^1.44.0"
    },
    "devDependencies": {
        "@types/node": "^22.13.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
