{
  "name": "@pumpkit/core",
  "version": "1.0.0",
  "description": "Shared utilities for PumpKit bots — logger, health server, config helpers, and common types",
  "license": "Apache-2.0",
  "author": "nirholas <https://github.com/nirholas> (https://x.com/nichxbt)",
  "homepage": "https://github.com/nirholas/atomic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nirholas/atomic.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/nirholas/atomic/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "node ../../tools/lint-check.mjs .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "peerDependencies": {
    "@nirholas/pump-sdk": "^1.30.0",
    "@solana/web3.js": "^1.98.0",
    "better-sqlite3": "^12.10.0",
    "grammy": "^1.43.0"
  },
  "peerDependenciesMeta": {
    "grammy": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    },
    "@nirholas/pump-sdk": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
