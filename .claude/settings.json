{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run dev:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm ls:*)",
      "Bash(npx tsx:*)",
      "Bash(npx vitest:*)",
      "Bash(make help)",
      "Bash(make build)",
      "Bash(make test)",
      "Bash(make typecheck)",
      "Bash(make lint)",
      "Bash(make dev-*)",
      "Bash(turbo run:*)",
      "Bash(bash tools/audit-dependencies.sh)",
      "Bash(bash tools/check-file-permissions.sh:*)",
      "Bash(bash tools/generate-vanity.sh:*)",
      "Bash(solana-keygen pubkey:*)",
      "Bash(solana-keygen --version)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Read(./tmp/leaked-launch/funder.json)",
      "Read(./**/*.env)",
      "Read(./**/keypair*.json)"
    ]
  }
}
