# Required — Telegram bot token from @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZabcdef-_0

# Required — primary Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Required — Telegram chat to broadcast alerts to
# Get this by sending a message to your bot and visiting:
# https://api.telegram.org/bot<TOKEN>/getUpdates
CHAT_ID=-1001234567890

# Optional — comma-separated fallback RPC URLs (used if primary fails)
# FALLBACK_RPC_URL=https://your-helius-url,https://your-quicknode-url

# Optional — POST every claim event to this URL with retry/backoff
# WEBHOOK_URL=https://your-server.example/pumpkit/webhook

# Optional — FileStore path for watched-tokens state (default: ./data/watched.json)
# STORE_PATH=./data/watched.json

# Optional — log verbosity (debug | info | warn | error)
# LOG_LEVEL=info
