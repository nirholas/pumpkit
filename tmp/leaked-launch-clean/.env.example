# Solana RPC. Public mainnet works; Helius/Triton recommended for production.
RPC_URL=https://api.mainnet-beta.solana.com

# Base58-encoded secret keys (export from Phantom/Solflare).
# NEVER commit real values. Keep in a local .env that's gitignored.
FUNDER_SECRET=YOUR_FUNDER_SECRET_BASE58_HERE
CREATOR_SECRET=YOUR_CREATOR_SECRET_BASE58_HERE

# Optional: path to a Solana CLI keypair JSON instead of base58
# FUNDER_KEYPAIR=./funder.json
# CREATOR_KEYPAIR=./creator.json

# --- Launch ---
NAME=MyCoin
SYMBOL=MEME
URI=https://ipfs.io/ipfs/PLACEHOLDER_METADATA_CID
DEV_BUY_SOL=0
JITO_TIP=0.005
PRIORITY=2000000

# --- Buy ---
TARGET_MINT=REPLACE_WITH_TARGET_MINT_ADDRESS
BUY_SOL=0.01
SLIPPAGE_BPS=500

# --- Collect ---
DESTINATION=REPLACE_WITH_YOUR_SAFE_WALLET

# --- Distribute (rewards bot) ---
MINT=REPLACE_WITH_YOUR_COIN_MINT
REWARD_PERCENT=80
MIN_BPS=10
